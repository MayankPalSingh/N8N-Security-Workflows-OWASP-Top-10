    {
      "parameters": {
        "jsCode": "// Parse the agent's structured output\n// Expected: ACTION: DELETE | TARGET: users | CONDITION: id = <value>\nconst agentOutput = $json.output;\n\nlet userId = null;\nlet action = null;\nlet target = null;\n\n// Parse structured format\nconst actionMatch = agentOutput.match(/ACTION:\\s*(\\w+)/i);\nconst targetMatch = agentOutput.match(/TARGET:\\s*(\\w+)/i);\nconst conditionMatch = agentOutput.match(/CONDITION:\\s*id\\s*=\\s*(\\d+)/i);\n\nif (actionMatch) action = actionMatch[1];\nif (targetMatch) target = targetMatch[1];\nif (conditionMatch) userId = parseInt(conditionMatch[1]);\n\n// Fallback: find any user ID number mentioned\nif (!userId) {\n  const numMatch = agentOutput.match(/(?:id|user)\\s*(?:=|:)?\\s*(\\d+)/i);\n  if (numMatch) userId = parseInt(numMatch[1]);\n}\n\nif (!userId) {\n  throw new Error('Could not extract user ID from agent output: ' + agentOutput);\n}\n\nreturn [{\n  json: {\n    userId,\n    action: action || 'DELETE',\n    target: target || 'users',\n    parsedFrom: agentOutput,\n    decision: 'Approved'\n  }\n}];"
      },
      "id": "f6d0c535-c5e4-42c2-97ba-7ee172d14d5f",
      "name": "Extract Params",
