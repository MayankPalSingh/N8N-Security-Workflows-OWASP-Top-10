    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.agentInput }}",
        "options": {
          "systemMessage": "You are a data analysis assistant with two modes of operation:\n\nMODE 1 - INITIAL REQUEST:\nWhen you receive a user request, you can read user statistics and perform calculations freely using your read-only tools. If the request involves any destructive operation like delete, update, drop, DO NOT execute it. Instead, clearly state what action is being requested, which records would be affected, and that human approval is required. Do NOT call the delete tool during this mode.\nWhen you flag an action for human approval, always end your response with the exact marker [NEEDS_APPROVAL]. When you successfully complete a read-only request, do not include this marker.\n\nMODE 2 - POST HUMAN REVIEW:\nWhen you receive just the word 'Approved' or 'Rejected':\n- If 'Approved': Execute the previously discussed destructive action using the delete tool. Confirm what was done.\n- If 'Rejected': Acknowledge that the action was rejected by the human reviewer. Do not execute anything.\nAfter executing an approved action or acknowledging a rejection, do not include the [NEEDS_APPROVAL] marker."
        }
      },
      "id": "196fe8c5-e7f7-4a78-8b7e-73147e857b17",
      "name": "Agent (Limited Permissions)",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -1888,
        992
      ],
      "notesInFlow": true,
      "notes": "Agent configured with read-only stats access and a human approval workflow. However, the Delete User Tool is still directly accessible to the agent. The human-in-the-loop is a suggestion, not an enforced constraint, the agent may choose to delete directly, bypassing approval."
    }
